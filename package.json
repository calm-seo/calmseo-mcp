{
  "name": "calmseo-mcp",
  "version": "0.1.0",
  "description": "Public tool definitions and local mock server for the CalmSEO MCP server.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.20.0",
  "keywords": [
    "mcp",
    "seo",
    "calmseo"
  ],
  "engines": {
    "node": ">=22"
  },
